# ── CHM Car backend env ──  copy to ".env" for local dev, or set these on Render.

# Server
PORT=3000
# Where the SQLite file lives. On Render with a persistent disk, use /var/data/chm.db
DB_PATH=./data/chm.db
# How long an unpaid booking holds inventory before release (ms). 900000 = 15 min
HOLD_TTL_MS=900000
# How often the hold-sweeper runs (ms)
SWEEP_MS=60000

# Auth — CHANGE THESE in production
JWT_SECRET=please-change-to-a-long-random-string
ADMIN_EMAIL=admin@chmcar.com
ADMIN_PASSWORD=change-me-now

# Stripe (TEST keys first). Leave STRIPE_SECRET_KEY blank to run the built-in MOCK gateway.
#   Test secret key starts with sk_test_...   Live starts with sk_live_...
STRIPE_SECRET_KEY=
#   Webhook signing secret from the Stripe dashboard (starts with whsec_...)
STRIPE_WEBHOOK_SECRET=
